###############################################################################
# Real Estate Intelligence Engine — environment template
#
# Copy to `.env` (repo root or realestate_engine/) and fill REAL values.
# The engine is designed to FAIL LOUDLY when fed fake or missing credentials.
###############################################################################

# ── Database (PostgreSQL is the production backend) ──────────────────────────
# Start Postgres with: docker compose up -d postgres
DATABASE_URL=postgresql://realestate:realestate_secure_2026@localhost:5432/realestate
SCHEDULER_DB_URL=postgresql://realestate:realestate_secure_2026@localhost:5432/realestate

# Local-only fallback (NOT for production):
# DATABASE_URL=sqlite:///data/db/realestate.db

# ── Redis (cache + per-portal rate limiter) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# When true, the engine refuses to start if Redis is unreachable.
REDIS_REQUIRED=false

# ── Telegram notifications (REQUIRED for Phase 5) ────────────────────────────
# Get a token via @BotFather and your chat id via @userinfobot or getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scraping / anti-bot (REQUIRED for real scraping) ─────────────────────────
# Residential proxy — BrightData / Oxylabs / Smartproxy. Example:
# RESIDENTIAL_PROXY_URL=http://user-sessionrand:password@gate.smartproxy.com:7000
RESIDENTIAL_PROXY_URL=
# Comma-separated fallback pool. Leave empty if not used.
PROXY_LIST=

# ── Scoring / Notification thresholds ────────────────────────────────────────
# Minimum score to trigger a Telegram notification (0-10)
MIN_SCORE_NOTIFICATION=8.0
# Maximum notifications per day (rate limit)
MAX_DAILY_NOTIFICATIONS=50
# Red flag: price/m² below this value is suspicious (€/m²)
RED_FLAG_PRICE_M2_CRITICAL=400
RED_FLAG_PRICE_M2_WARNING=700
# Red flag: discount below this means severely overpriced (negative = overpriced)
RED_FLAG_OVERPRICED_SEVERE=-0.25
RED_FLAG_OVERPRICED_MODERATE=-0.15
# Score caps for listings with missing data
SCORE_CAP_NO_PHOTOS=5.0
SCORE_CAP_NO_COORDS=7.2
SCORE_CAP_WITH_FLAGS=8.0
# Imperdível classification thresholds
IMPERDIVEL_MIN_SCORE=9.0
IMPERDIVEL_MIN_DISCOUNT_PCT=15.0

# ── Paths (override defaults if needed) ──────────────────────────────────────
# DATA_DIR=data
# DB_DIR=data/db
# BACKUP_DIR=data/backups
# CACHE_DIR=data/cache

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
JSON_LOGS=false
LOG_RETENTION_DAYS=30
LOG_ROTATION_SIZE=50 MB
PROMETHEUS_PORT=8000

# ── Feature flags ────────────────────────────────────────────────────────────
ENABLE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Skip heavy CV/NLP enrichers (image quality, BERT sentiment, NER, summariser).
# Set to 1 when running on a machine without torch/transformers installed,
# or for fast bootstrap runs. Default: 0 (run heavy enrichers when available).
ENRICH_SKIP_HEAVY=0

# ── AI deals (local Ollama LLM) ──────────────────────────────────────────────
# Used by the dashboard view "Melhores Deals IA". Ollama must be running
# locally (`ollama serve`) and the model pulled (`ollama pull mistral:7b`).
# Switch to qwen3-14b-fast or qwen3-35b-q4 by changing OLLAMA_MODEL only.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b
# Connect timeout (s): fail fast when Ollama is down.
OLLAMA_CONNECT_TIMEOUT_S=5
# Read timeout (s): cold-start of a 7B model on CPU can exceed 60 s; bump
# this if you use larger models (qwen3-35b-q4 may need 300 s).
OLLAMA_READ_TIMEOUT_S=180
# Keep model resident in memory between calls. Accepts Ollama duration
# strings: "30m", "2h", "-1" (forever), "0" (unload immediately).
OLLAMA_KEEP_ALIVE=30m
# Number of automatic retries on ReadTimeout. The retry usually succeeds
# in a fraction of the cold-start time.
OLLAMA_MAX_RETRIES=1
# Where to cache successful AI theses (one JSON file per listing+model).
AI_DEALS_CACHE_DIR=data/cache/ai_deals

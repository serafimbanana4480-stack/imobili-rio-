FROM qwen3:14b

# Usar 100% da CPU - 12 threads
PARAMETER num_thread 12
PARAMETER num_ctx 8192
PARAMETER num_batch 1024

# Mais rápido mas ligeiramente menos criativo
PARAMETER temperature 0.6
PARAMETER top_p 0.85
PARAMETER repeat_penalty 1.1

SYSTEM """You are an optimized AI assistant running on full CPU power. Provide fast, accurate, and concise responses."""

###############################################################################
# Real Estate Intelligence Engine — environment template
#
# Copy to `.env` (repo root or realestate_engine/) and fill REAL values.
# The engine is designed to FAIL LOUDLY when fed fake or missing credentials.
###############################################################################

# ── Database (PostgreSQL is the production backend) ──────────────────────────
# Start Postgres with: docker compose up -d postgres
DATABASE_URL=postgresql://realestate:realestate_secure_2026@localhost:5432/realestate
SCHEDULER_DB_URL=postgresql://realestate:realestate_secure_2026@localhost:5432/realestate

# Database connection pooling (for PostgreSQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# Local-only fallback (NOT for production):
# DATABASE_URL=sqlite:///data/db/realestate.db

# ── Ollama (AI Analysis - optional) ──────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b
# Cache TTL for AI analysis (hours, 0 = never expire)
AI_DEALS_CACHE_TTL_HOURS=24

# ── Redis (cache + per-portal rate limiter) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# When true, the engine refuses to start if Redis is unreachable.
REDIS_REQUIRED=false

# ── Telegram notifications (REQUIRED for Phase 5) ────────────────────────────
# Get a token via @BotFather and your chat id via @userinfobot or getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scraping / anti-bot (REQUIRED for real scraping) ─────────────────────────
# Residential proxy — BrightData / Oxylabs / Smartproxy. Example:
# RESIDENTIAL_PROXY_URL=http://user-sessionrand:password@gate.smartproxy.com:7000
RESIDENTIAL_PROXY_URL=
# Comma-separated fallback pool. Leave empty if not used.
PROXY_LIST=

# ── Scheduler (minutes between cycles) ───────────────────────────────────────
SCRAPING_INTERVAL_MINUTES=30
ETL_INTERVAL_MINUTES=32
VALUATION_INTERVAL_MINUTES=35
SCORING_INTERVAL_MINUTES=38
NOTIFICATION_INTERVAL_MINUTES=60

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PROMETHEUS_PORT=8000

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT Configuration (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins for API (comma-separated). Use "*" only in development.
CORS_ORIGINS=*

# ── Feature flags ────────────────────────────────────────────────────────────
ENABLE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
